<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen p-10 bg-zinc-800 text-white">
      <div class="w-full flex justify-end">
        <a class="px-3 py-2 mb-3 inline-block rounded-md text-sm bg-red-800" href="/logout">Logout</a>
      </div>
      <h3 class="text-3xl ">
        <span class="font-light">Hello,</span> <%= user.name %>
      </h3>
      <h5 class="mb-5" >You can create new post</h5>
      <form method="post" action="/post">
        <textarea placeholder="Whats on your mind ?" class="w-1/3 p-3 block resize-none outline-none rounded-md border-2 bg-transparent" name="content"></textarea>
        <input class="px-5 py-2 w-40 mt-3 text-sm block rounded-md bg-blue-600 " type="submit" value="Create new post">
      </form>
      <div class="posts mt-20">
        <h3 class="text-zinc-400">Your Posts</h3>
        <div class="postcontainer mt-5">
          <% user.posts.reverse().forEach(function(post){ %>
            <div class="post w-1/3 p-4 mb-2 rounded-md border-[1px] border-zinc-600 bg-zinc-800">
              <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
              <p class="text-sm tracking-tight"><%= post.content %></p>
              <small class="mt-2 inline-block"><%= post.likes.length %> likes</small>
              <div class="btns flex mt-1 gap-4">
                
                <form action="/like/<%= post._id %>" method="post">
                  <button class="text-blue-500" type="submit">
                    <%= (post.likes.indexOf(user._id)===-1) ? "like":"unlike" %>
                  </button>
                </form>

                <a class="text-zinc-600" href="/edit/<%= post._id %>">edit</a>
              </div>
            </div>
          <% }) %>

        </div>
      </div>
    </div>
  </body>
</html>
