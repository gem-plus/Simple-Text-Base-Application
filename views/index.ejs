<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen p-10 bg-zinc-800 text-white ">
      <h3 class="text-3xl mb-5">Create Account</h3>
      <form action="/register" method="post">
        <input class="px-3 py-2 rounded-md bg-zinc-700 border-2 border-zinc-600 outline-none" type="text" placeholder="username" name="username">
        <input class="px-3 py-2 rounded-md bg-zinc-700 border-2 border-zinc-600 outline-none" type="text" placeholder="name" name="name">
        <input class="px-3 py-2 rounded-md bg-zinc-700 border-2 border-zinc-600 outline-none" type="number" placeholder="age" name="age">
        <input class="px-3 py-2 rounded-md bg-zinc-700 border-2 border-zinc-600 outline-none" type="email" placeholder="email" name="email">
        <input class="px-3 py-2 rounded-md bg-zinc-700 border-2 border-zinc-600 outline-none" type="password" placeholder=" password" name="password">
        <input class="px-5 py-2 rounded-md bg-blue-600"  type="submit" value="Create Account">
      </form>
    </div>
  </body>
</html>
