<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen p-10 bg-zinc-800 text-white">
      <div class="w-full flex justify-end">
        <a class="px-3 py-2 mb-3 inline-block rounded-md text-sm bg-red-800" href="/logout">Logout</a>
      </div>
      <h5 class="mb-5" >Edit your post</h5>
      <form method="post" action="/update/<%= post._id %>">
        <textarea  class="w-1/3 p-3 block resize-none outline-none rounded-md border-2 bg-transparent" name="content"><%= post.content  %></textarea>
        <input class="px-5 py-2 w-40 mt-3 text-sm block rounded-md bg-blue-600 " type="submit" value="Update post">
      </form>
    </div>
  </body>
</html>
